---
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';
import { readFileSync } from 'fs';
import { join } from 'path';
import { getCollection } from 'astro:content';

const manifestoText = readFileSync(join(process.cwd(), 'src/content/manifesto.md'), 'utf8');
const manifestoHtml = marked.parse(manifestoText);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const formatDate = (d: Date) =>
  `${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,'0')}-${String(d.getUTCDate()).padStart(2,'0')}`;

const base = import.meta.env.BASE_URL;
---
<Layout
  title="Events All the Way Down"
  description="A blog on process ontology, intelligence, and becoming — by Franklin Silveira Baldo"
>
  <main class="container">
    {posts.length > 0 && (
      <section style="margin-bottom: 3rem;">
        <h2 style="font-size:1rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); border: none; margin-bottom: 1rem;">Latest posts</h2>
        <ul class="post-list">
          {posts.map(post => (
            <li>
              <a href={`${base}blog/${post.id}`} class="post-title">{post.data.title}</a>
              <div class="post-date">{formatDate(post.data.date)}</div>
              {post.data.description && <p class="post-desc">{post.data.description}</p>}
            </li>
          ))}
        </ul>
      </section>
    )}

    <hr />

    <div class="manifesto-body" set:html={manifestoHtml} />
  </main>
</Layout>
