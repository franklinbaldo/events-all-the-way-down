---
import '../styles/global.css';
import { marked } from 'marked';
import { readFileSync } from 'fs';
import { join } from 'path';
import { getCollection } from 'astro:content';

const manifestoText = readFileSync(join(process.cwd(), 'src/content/manifesto.md'), 'utf8');
const manifestoHtml = marked.parse(manifestoText);

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const formatDate = (d: Date) =>
  `${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,'0')}-${String(d.getUTCDate()).padStart(2,'0')}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Events All the Way Down</title>
  <meta name="description" content="A blog on process ontology, intelligence, and becoming — by Franklin Silveira Baldo" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <nav>
        <a href="/events-all-the-way-down/" class="site-title">Events All the Way Down</a>
        <a href="/events-all-the-way-down/blog" class="nav-link">Posts</a>
        <a href="https://franklinbaldo.github.io" class="nav-link">Main blog ↗</a>
      </nav>
    </div>
  </header>

  <main class="container">
    {posts.length > 0 && (
      <section style="margin-bottom: 3rem;">
        <h2 style="font-size:1rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); border: none; margin-bottom: 1rem;">Latest posts</h2>
        <ul class="post-list">
          {posts.map(post => (
            <li>
              <a href={`/events-all-the-way-down/blog/${post.slug}`} class="post-title">{post.data.title}</a>
              <div class="post-date">{formatDate(post.data.date)}</div>
              {post.data.description && <p class="post-desc">{post.data.description}</p>}
            </li>
          ))}
        </ul>
      </section>
    )}

    <hr />

    <div class="manifesto-body" set:html={manifestoHtml} />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>By <a href="https://franklinbaldo.github.io">Franklin Silveira Baldo</a> · Also at <a href="https://franklinbaldo.github.io">franklinbaldo.github.io</a></p>
    </div>
  </footer>
</body>
</html>
