---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  `${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,'0')}-${String(d.getUTCDate()).padStart(2,'0')}`;

const base = import.meta.env.BASE_URL;
---
<Layout title="Posts — Events All the Way Down">
  <main class="container">
    <h1 style="margin-bottom: 2rem;">Posts</h1>
    <ul class="post-list">
      {posts.map(post => (
        <li>
          <a href={`${base}blog/${post.id}`} class="post-title">{post.data.title}</a>
          <div class="post-date">{formatDate(post.data.date)}</div>
          {post.data.description && <p class="post-desc">{post.data.description}</p>}
        </li>
      ))}
    </ul>
  </main>
</Layout>
