---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  `${d.getUTCFullYear()}-${String(d.getUTCMonth()+1).padStart(2,'0')}-${String(d.getUTCDate()).padStart(2,'0')}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Posts — Events All the Way Down</title>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <nav>
        <a href="/events-all-the-way-down/" class="site-title">Events All the Way Down</a>
        <a href="/events-all-the-way-down/blog" class="nav-link">Posts</a>
        <a href="https://franklinbaldo.github.io" class="nav-link">Main blog ↗</a>
      </nav>
    </div>
  </header>
  <main class="container">
    <h1 style="margin-bottom: 2rem;">Posts</h1>
    <ul class="post-list">
      {posts.map(post => (
        <li>
          <a href={`/events-all-the-way-down/blog/${post.slug}`} class="post-title">{post.data.title}</a>
          <div class="post-date">{formatDate(post.data.date)}</div>
          {post.data.description && <p class="post-desc">{post.data.description}</p>}
        </li>
      ))}
    </ul>
  </main>
</body>
</html>
