---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.svelte';
import SearchModal from '../components/SearchModal.svelte';

interface Props {
  title: string;
  description?: string;
  /** Canonical URL for OG tags — defaults to current page URL */
  canonicalUrl?: string;
  /** OG image absolute URL — optional */
  ogImage?: string;
  /** Article-specific OG type; defaults to 'website' */
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage,
  ogType = 'website',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteName = 'Events All the Way Down';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{title}</title>
  {description && <meta name="description" content={description} />}

  <!-- Open Graph / Social cards -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={canonicalUrl} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter / X card -->
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <link rel="canonical" href={canonicalUrl} />

  <!-- Restore saved theme before first paint to prevent flash -->
  <script is:inline>
    (function () {
      var t = localStorage.getItem('theme') ||
        (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.dataset.theme = t;
    })();
  </script>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <nav>
        <a href={base} class="site-title">{siteName}</a>
        <a href={`${base}/blog`} class="nav-link">Posts</a>
        <a href="https://franklinbaldo.github.io" class="nav-link">Main blog ↗</a>
        <SearchModal client:load />
        <ThemeToggle client:idle />
      </nav>
    </div>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="container">
      <p>By <a href="https://franklinbaldo.github.io">Franklin Silveira Baldo</a> · Also at <a href="https://franklinbaldo.github.io">franklinbaldo.github.io</a></p>
    </div>
  </footer>
</body>
</html>
